# ═══════════════════════════════════════════
# PANGKASKAKA BACKEND — ENVIRONMENT EXAMPLE
# ═══════════════════════════════════════════
# Cara pakai:
#   1. Copy file ini: cp .env.example .env
#   2. Isi credentials asli di .env
#   3. .env SUDAH di-gitignore, AMAN di-commit
# ═══════════════════════════════════════════

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration — PostgreSQL
# Ganti dengan credentials database kamu
DATABASE_URL="postgresql://username:password@localhost:5432/pangkaskaka"

# For production use:
# DATABASE_URL="postgresql://username:password@db.example.com:5432/pangkaskaka"

# JWT Configuration
# Ganti dengan secret key yang kuat untuk production
JWT_SECRET=your_secret_key_here

# API Configuration
# CORS_ORIGIN=http://localhost:5173
