# ============================================
# DATABASE PROTECTION - JANGAN DIHAPUS!
# Bagian ini critical untuk keamanan database.
# ============================================

# Environment variables (mengandung credentials database)
.env
.env.local
.env.*.local
.env.*
!.env.example

# Database files - semua format database file
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlitedb
*.db3
*.dbf
*.mdb
*.accdb

# Database dump / backup files (sering mengandung data sensitif)
*.sql
*.dump
*.dmp
*.bak
*.backup
*.pgdump
*.pg_backup

# Backup directories
backups/
backup/
db_backup/
database_backup/
pg_backup/
db_dumps/
pg_dump/

# Dataset - file data mentah (CSV, Excel, SQL)
Dataset/*.sql
Dataset/*.csv
Dataset/*.xlsx
Dataset/*.xls
Dataset/*.zip
Dataset/*.rar
Dataset/*.7z
Dataset/Data Barber Kupang/

# Prisma local development database
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.sqlite

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# IDE
.vscode/
.idea/
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Build outputs
dist/
build/

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.cache/
*.temp
*.swp

# Secret / credential files (apapun)
*.key
*.pem
*.cert
credentials*
secret*
