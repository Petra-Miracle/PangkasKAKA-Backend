{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x",
      "memory": 256,
      "maxDuration": 10,
      "environment": {
        "NODE_ENV": "production"
      }
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "env": [
    {
      "key": "DATABASE_URL",
      "description": "PostgreSQL database connection URL"
    },
    {
      "key": "JWT_SECRET",
      "description": "JWT secret key for token generation"
    },
    {
      "key": "NODE_ENV",
      "value": "production"
    }
  ]
}
