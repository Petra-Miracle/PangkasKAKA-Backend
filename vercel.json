{
  "version": 2,
  "buildCommand": "prisma generate --schema=PangkasDB/prisma/schema.prisma",
  "installCommand": "npm install --include=dev prisma @prisma/config",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
